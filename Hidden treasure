#include<bits/stdc++.h>
using namespace std;
 
int digitSum(int x) {
    x = abs(x);
    int sum = 0;
    while (x > 0) {
        sum += x % 10;
        x /= 10;
    }
    return sum;
}
 
long long solve (int n, vector<int> nums) {
    unordered_map<int, long long> freq;
 
    for (int num : nums) {
        freq[digitSum(num)]++;
    }
 
    long long pairs = 0;
 
   
    for (auto &p : freq) {
        long long c = p.second;
        pairs += c * (c - 1) / 2;
    }
 
    return pairs;
}
 
int main() {
 
    ios::sync_with_stdio(0);
    cin.tie(0);
 
    int n;
    cin >> n;
    vector<int> nums(n);
 
    for(int i = 0; i < n; i++)
        cin >> nums[i];
 
    long long out_;
    out_ = solve(n, nums);
    cout << out_;
}
